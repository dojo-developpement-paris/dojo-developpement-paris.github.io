{
    "nixEnvSelector.useFlakes": true,
    "nixEnvSelector.nixFile": "${workspaceFolder}/flake.nix",
    "devbox.autoShellOnTerminal": false,
    "files.associations": {
        "devbox.json": "jsonc",
    },
    "editor.formatOnSave": true,
    "rust-analyzer.checkOnSave": true,
    "rust-analyzer.hover.actions.references.enable": true,
    "rust-analyzer.imports.granularity.enforce": true,
    "rust-analyzer.cachePriming.enable": true,
    "rust-analyzer.lens.references.adt.enable": true,
    "rust-analyzer.lens.references.enumVariant.enable": true,
    "rust-analyzer.lens.references.method.enable": true,
    "rust-analyzer.lens.references.trait.enable": true,
    "rust-analyzer.typing.autoClosingAngleBrackets.enable": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "editor.inlayHints.enabled": "off",
    "editor.inlineSuggest.edits.allowCodeShifting": "never",
    "editor.inlineSuggest.edits.renderSideBySide": "never",
    "editor.inlineSuggest.enabled": false,
    "workbench.colorTheme": "Visual Studio Light",
    "editor.fontWeight": "normal",
    "window.zoomLevel": 1,
    "debug.console.fontSize": 26,
    "editor.fontSize": 26,
    "markdown.preview.fontSize": 26,
    "terminal.integrated.fontSize": 26,
    "customPresentationMode.backup": {},
}
